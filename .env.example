# ============================================================================
#  Configuración de MarkItDown Web — copiá a ".env" y ajustá.
#  En EasyPanel: cargá estas variables en la pestaña "Environment" del servicio.
# ============================================================================

# --- SEGURIDAD / SESIONES ---------------------------------------------------
# Clave para firmar las sesiones. GENERÁ UNA y fijala (si no, las sesiones se
# reinician en cada deploy). Ej: openssl rand -hex 32
SECRET_KEY=

# Duración de la sesión (horas)
SESSION_TTL_HOURS=12

# --- CONTRASEÑAS POR ROL ----------------------------------------------------
# Definí al menos una. Si dejás un rol vacío, ese rol no puede loguearse.
#   DIOS   = poder total (URLs internas, file://, rutas locales, sin límites)
#   ANGEL  = archivos + URLs públicas (anti-SSRF), límites medios
#   HUMANO = solo archivos, límites estrictos
GOD_PASSWORD=
ANGEL_PASSWORD=
HUMAN_PASSWORD=

# Permitir el nivel HUMANO sin login (conversor público). true/false
HUMAN_OPEN=false

# --- TOKEN DE API (para n8n / scripts, sin login con cookie) ----------------
# Si lo definís, podés llamar a /api/convert con el header:
#   Authorization: Bearer <API_TOKEN>   o   X-API-Key: <API_TOKEN>
# Generá uno fuerte: openssl rand -hex 32
API_TOKEN=
# Rol que obtiene quien use ese token (dios/angel/humano)
API_TOKEN_ROLE=angel

# --- CLAVES DE IA DEL SERVIDOR (opcionales) ---------------------------------
# Si las definís, los usuarios NO necesitan pegar su propia API key: se usa la
# del servidor para describir imágenes / OCR con IA. Solo las usan DIOS y ANGEL
# (HUMANO debe traer la suya). ⚠️ El costo corre por tu cuenta. Dejalas vacías
# para que cada uno use la suya. La key del usuario (si la pega) tiene prioridad.
OPENAI_API_KEY=
OPENROUTER_API_KEY=
GOOGLE_API_KEY=          # Gemini (Google AI Studio). Alias: GEMINI_API_KEY

# --- LÍMITES POR ROL (opcionales; 0 = sin límite) ---------------------------
# Tamaño máximo por archivo (MB)
GOD_MAX_MB=0
ANGEL_MAX_MB=100
HUMAN_MAX_MB=25
# Archivos por lote
GOD_MAX_BATCH=0
ANGEL_MAX_BATCH=10
HUMAN_MAX_BATCH=3
# Rate limit (requests por minuto por IP; 0 = sin límite)
GOD_RATE=0
ANGEL_RATE=60
HUMAN_RATE=15

# Tope ABSOLUTO de subida para todos salvo DIOS (MB)
MAX_UPLOAD_MB=100

# --- RENDIMIENTO ------------------------------------------------------------
# "auto" = usa todos los núcleos del server. Cada worker ~250 MB RAM.
#   Modesto: 2   ·   Medio: 4   ·   Grande: 8   ·   Bestia: auto
WEB_CONCURRENCY=auto

# Redis para rate-limit EXACTO entre todos los workers.
# Por defecto va EMBEBIDO dentro del contenedor (se prende solo, cero config).
#   EMBEDDED_REDIS=true   -> Redis local automático (recomendado, 1 contenedor)
#   EMBEDDED_REDIS=false  -> sin Redis local
# Para un Redis EXTERNO (al escalar a varias instancias): poné EMBEDDED_REDIS=false
# y definí REDIS_URL. Si REDIS_URL está seteado, se usa ese y se ignora el embebido.
EMBEDDED_REDIS=true
# REDIS_URL=redis://redis:6379/0

# Umbral para detectar PDF escaneado: si extrae menos de N caracteres, aplica OCR auto.
SCANNED_THRESHOLD=30

# --- TRANSCRIPCIÓN (audio/video) --------------------------------------------
# Modelo Whisper: tiny/base/small/medium/large-v3 (mayor = más preciso y lento)
WHISPER_MODEL=base
# Tope de duración de audio/video a transcribir, en minutos (0 = sin límite).
# DIOS no tiene tope. Protege la CPU de transcripciones gigantes.
MAX_MEDIA_MINUTES=120

# --- TEXTO → AUDIO / PODCAST (TTS) ------------------------------------------
# Convierte el documento a MP3 (narración o podcast a 2 voces).
# Motor LOCAL (Piper): el texto no sale del servidor; voces horneadas en la imagen.
# Motor CLOUD opcional (OpenAI TTS): usa la API key del usuario (mejor calidad).
# Habilitado para ANGEL y DIOS (como audio/OCR); HUMANO con HUMAN_TTS=true.
ENABLE_TTS=true
# Tope de caracteres por pedido de audio, POR ROL (protege la CPU; 0 = sin límite).
# Más caracteres = audio más largo = más CPU/tiempo (hay un timeout por pedido).
GOD_TTS_CHARS=0           # DIOS: sin límite (recomendado)
ANGEL_TTS_CHARS=100000    # ANGEL: ~100k caracteres (subilo/bajalo según tu CPU)
HUMAN_TTS_CHARS=20000     # HUMANO: solo aplica si HUMAN_TTS=true
# Modelo de OpenAI TTS: tts-1 (rápido) o tts-1-hd (más calidad). Usa la key del usuario.
TTS_OPENAI_MODEL=tts-1
# Permitir que el rol HUMANO genere audio (por defecto no).
# HUMAN_TTS=false
# Timeout por pedido de síntesis, en segundos (corta audios demasiado largos).
# TTS_TIMEOUT=600
# Rutas internas (normalmente NO tocar; ya vienen seteadas en la imagen):
# PIPER_BIN=/opt/piper/piper
# PIPER_VOICES_DIR=/opt/piper-voices

# --- YouTube (transcripciones) ----------------------------------------------
# YouTube a veces bloquea los pedidos de subtítulos desde IPs de servidor.
# La app ya prueba varios "clientes" de YouTube (android/ios/tv/web) para
# esquivar el bloqueo. Si AÚN te falla "obtener la transcripción":
#   - OPCIÓN FÁCIL: cada usuario puede pegar su propio cookies.txt desde la web,
#     en ⚙ Configuración → "Cookies de YouTube" (no requiere tocar el server).
#   - O bien configurá una de estas variables a nivel server:
#   YT_PROXY    : enruta los pedidos por un proxy (ideal: residencial).
#   YT_COOKIES  : ruta a un cookies.txt de una sesión logueada de YouTube
#                 (exportado con una extensión tipo "Get cookies.txt").
YT_PROXY=
YT_COOKIES=

# --- ANONIMIZACIÓN DE PII (Anonimal / OpenAI Privacy Filter) ----------------
# Anonimal es un microservicio APARTE (imagen ghcr.io/diegoparras/anonimal) que
# detecta y enmascara datos personales (nombres, emails, DNI/CUIT/CBU, etc.).
# Si definís ANONIMAL_URL, Escriba habilita el modo "Anonimizar". Dejalo vacío
# para desactivar la función. El servicio debe estar SOLO en la red interna.
ANONIMAL_URL=
# Ej. en docker-compose / EasyPanel (red interna): http://anonimal:8000
# Read timeout (segundos) del pedido a Anonimal. Subilo para documentos grandes
# (la inferencia en CPU tarda). Default 180. Poné 0 para SIN límite de lectura.
ANONIMAL_TIMEOUT=180

# --- VARIOS -----------------------------------------------------------------
# Exponer Swagger en /api/docs (solo recomendado en dev). true/false
ENABLE_DOCS=false
# Forzar cookie Secure aunque el server vea http (poné true si hay HTTPS por proxy)
COOKIE_SECURE=
# Puerto interno
PORT=8000
